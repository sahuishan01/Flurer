{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "git-plugin-shell",
  "description": "Allows the git plugin to execute git commands via the shell plugin",
  "windows": ["main"],
  "permissions": [
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "git",
          "cmd": "git",
          "args": true,
          "sidecar": false
        }
      ]
    }
  ]
}