{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the main window — grants all plugins access to shell execution and core APIs",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "opener:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "git",
          "cmd": "git",
          "args": true,
          "sidecar": false
        },
        {
          "name": "sh",
          "cmd": "sh",
          "args": true,
          "sidecar": false
        }
      ]
    }
  ]
}